---
import Navigation from "../components/Navigation.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{frontmatter?.title ?? "Delilah’s Journey"}</title>

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600&display=swap');

      html, body {
        margin: 0;
        padding: 0;
        background: #f8f5f2;
        color: #1f1a17;
      }

      body {
        font-family: 'Inter', sans-serif;
        line-height: 1.7;
      }

      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 60px 24px;
      }

      h1, h2, h3 {
        font-family: 'Playfair Display', serif;
        color: #2c1d18;
        line-height: 1.15;
      }

      h1 {
        font-size: 2.8rem;
        margin-bottom: 1rem;
      }

      p {
        font-size: 1.05rem;
        color: #3d342f;
      }

      li {
        margin-bottom: 0.5rem;
      }

      a {
        color: #7a2e2e;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .back {
        display: inline-block;
        margin-bottom: 20px;
        font-weight: 600;
        color: #7a5c4d;
      }

      .post-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 60px 24px;
      }

      .post-card {
      background: #f7f1ee;
      padding: 32px;
      border-radius: 16px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
	  }


      .post-card h1 {
  font-size: 2.2rem;
  margin-bottom: 16px;
}

.post-card h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;   
  font-weight: 400;    
  line-height: 1.3;
  margin-top: 32px;
  margin-bottom: 10px;
  color: #2c1d18;     
  color: #2c1d18;
}

     .post-card p {
  line-height: 1.7;
  margin-bottom: 14px;
}

      .post-meta {
        color: #7a675f;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
      }

      blockquote {
        margin: 2rem 0;
        padding: 1rem 1.25rem;
        border-left: 4px solid #b07d62;
        background: #f4ece7;
        color: #493730;
        font-style: italic;
      }
    </style>
  </head>

<body>
 <Navigation />	
<Header> </Header>
   <main>
  <a href="/blog/" class="back">← Back to Blog</a>

  <article class="post-card">
  <h1>{frontmatter?.title ?? "Delilah’s Journey"}</h1>
    <slot />
  </article>
</main>
  </body>
</html>