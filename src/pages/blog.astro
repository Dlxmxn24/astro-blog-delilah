---
import Footer from "../components/Footer.astro";

const postFiles = import.meta.glob("./posts/*.md", { eager: true });
const posts = Object.values(postFiles);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog | Delilah’s Journey</title>

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600&display=swap');

      html, body {
        margin: 0;
        padding: 0;
        background: #f8f5f2;
        color: #1f1a17;
      }

      body {
        font-family: 'Inter', sans-serif;
        line-height: 1.7;
      }

      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 60px 24px;
      }

      h1, h2 {
        font-family: 'Playfair Display', serif;
        line-height: 1.15;
        margin-top: 0;
        color: #2c1d18;
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 1rem;
      }

      .nav {
        margin-bottom: 2rem;
      }

      .nav a {
        margin-right: 1rem;
        font-weight: 600;
        color: #7a2e2e;
        text-decoration: none;
      }

      .nav a:hover {
        text-decoration: underline;
      }

      .post-list {
        list-style: none;
        padding: 0;
      }

      .post-item {
        background: #fffdfb;
        border: 1px solid #eadfd7;
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 10px 30px rgba(44, 29, 24, 0.06);
      }

      .post-item a {
        font-size: 1.2rem;
        font-weight: 600;
        color: #7a2e2e;
        text-decoration: none;
      }

      .post-item a:hover {
        text-decoration: underline;
      }
    </style>
  </head>

  <body>
    <main>
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
        <a href="/tags/">Tags</a>
      </nav>

      <h1>Blog</h1>

      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <a href={post.url}>{post.frontmatter.title}</a>
          </li>
        ))}
      </ul>
    </main>

    <Footer />
  </body>
</html>