---
import Footer from "../components/Footer.astro";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Delilah’s Journey</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600&display=swap');

      html, body {
        margin: 0;
        padding: 0;
        background: #f8f5f2;
        color: #1f1a17;
      }

      body {
        font-family: 'Inter', sans-serif;
        line-height: 1.7;
      }

      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 60px 24px;
      }

      h1, h2 {
        font-family: 'Playfair Display', serif;
        line-height: 1.15;
        margin-top: 0;
        color: #2c1d18;
      }

      h1 {
        font-size: 3.2rem;
        margin-bottom: 1rem;
      }

      h2 {
        font-size: 2rem;
        margin-top: 2rem;
      }

      a {
        color: #7a2e2e;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .hero-tag {
        display: inline-block;
        margin-bottom: 1rem;
        padding: 0.35rem 0.8rem;
        border-radius: 999px;
        background: #ead9cf;
        color: #5d2a2a;
        font-size: 0.9rem;
        font-weight: 600;
      }

      .subtitle {
        font-size: 1.15rem;
        color: #5a4a42;
        max-width: 680px;
      }

      .card {
        background: #fffdfb;
        border: 1px solid #eadfd7;
        border-radius: 18px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(44, 29, 24, 0.06);
        margin-top: 2rem;
      }

      .nav {
        margin-bottom: 2rem;
      }

      .nav a {
        margin-right: 1rem;
        font-weight: 600;
      }

      .footer {
  max-width: 820px;
  margin: 40px auto 0;
  padding: 32px 24px 50px;
  border-top: 1px solid #eaded8;
  color: #6b5a52;
}

.footer-note {
  font-style: italic;
}

.socials {
  margin-top: 16px;
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.socials a {
  background: #ead6ce;
  color: #7a2e2e;
  padding: 8px 14px;
  border-radius: 999px;
  font-weight: 600;
  text-decoration: none;
}
    </style>
  </head>
  <body>
    <main>
      <nav class="nav">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
      </nav>

      <span class="hero-tag">Life Insurance Journey</span>
      <h1>Delilah’s Journey</h1>
      <p class="subtitle">
        Documenting my journey as a life insurance agent — the failures, growth,
        and lessons behind becoming licensed and building something meaningful.
      </p>

      <section class="card">
        <h2>Why I Started</h2>
        <p>
          I didn’t start this journey with confidence — I started it with uncertainty.
          Failing my exams more than once made me question myself, but I kept going.
          This blog is where I share the real side of growth: persistence, discipline,
          and becoming who you’re meant to be.
        </p>
      </section>

      <section class="card">
        <h2>Featured Post</h2>
        <p>Start here with the beginning of my journey.</p>
        <ul>
          <li><a href="/posts/post-1/">From Initial Hire to Licensed Agent</a></li>
        </ul>
      </section>
    </main>
    <footer class="footer">
  <p>© 2026 Delilah’s Journey</p>
  <p class="footer-note">Connect with me and follow the journey. ✨</p>

  <div class="socials">
    <a href="https://www.instagram.com/lifewlemenaid?igsh=ZDdtYThyMmp5NzJq&utm_source=qr" target="_blank">Instagram</a>
    <a href="https://www.facebook.com/share/1PGzSwXRLz/?mibextid=wwXIfr" target="_blank">Facebook</a>
    <a href="https://snapchat.com/t/ISNqF6wl" target="_blank">Snapchat</a>
  </div>
</footer>
  </body>
</html>